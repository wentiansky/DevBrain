# =============================================================================
# DevBrain 环境变量示例
# 复制为 .env 后填入实际值。本地开发不需要所有变量都填写。
# 当前 change (bootstrap) 不需要任何外部凭证即可完成验证。
# =============================================================================

# ---------- 镜像与部署 ----------
IMAGE_TAG=latest
REGISTRY=
IMAGE_PREFIX=devbrain/

# ---------- 端口 ----------
POSTGRES_PORT=5432
REDIS_PORT=6379
API_PORT=3001
WEB_PORT=3000
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

# ---------- 数据库 ----------
POSTGRES_USER=devbrain
POSTGRES_PASSWORD=devbrain
POSTGRES_DB=devbrain
DATABASE_URL=postgresql://devbrain:devbrain@localhost:5432/devbrain

# ---------- Redis ----------
REDIS_URL=redis://localhost:6379

# ---------- 对象存储 ----------
# P0 local adapter 数据目录，开发环境使用本地文件系统
# 生产环境必须配置 R2 系列变量，禁止 local adapter 暴露到公网
DEV_STORAGE_ROOT=.devbrain/storage
STORAGE_SIGNATURE_SECRET=change-me-storage-signature-secret
# local adapter 签名 token 默认有效期（秒），默认 300（5 分钟）
STORAGE_TOKEN_TTL_SECONDS=300

# ---------- Auth ----------
# JWT access token 签名密钥，必填
JWT_ACCESS_SECRET=change-me-access-secret
# access token 有效期秒数，默认 900（15 分钟），实际值不得超过 900
AUTH_ACCESS_TOKEN_TTL_SECONDS=900
# refresh token 有效期秒数，默认 604800（7 天），实际值不得超过 604800
AUTH_REFRESH_TOKEN_TTL_SECONDS=604800
# refresh token pepper，用于防御数据库泄露后的离线枚举
# 本地开发可不填，使用默认开发 pepper；生产环境必须显式配置，否则 API 启动失败
REFRESH_TOKEN_PEPPER=change-me-refresh-token-pepper
# refresh cookie 名称，默认 devbrain_refresh
AUTH_COOKIE_NAME=devbrain_refresh
# refresh cookie path，默认 /auth
AUTH_COOKIE_PATH=/auth
# 生产环境必须为 true；本地开发可设为 false 以启用 HTTP 调试
AUTH_COOKIE_SECURE=false

# ---------- CORS ----------
# 前端地址，多个用逗号分隔；本地开发默认 http://localhost:3000
# 生产环境禁止使用 * 搭配 credentials
CORS_ORIGIN=http://localhost:3000

# ---------- Embedding ----------
# 可选: mock（本地测试，默认）、dashscope（真实阿里云 DashScope）
EMBEDDING_PROVIDER=mock
# DashScope API Key，仅 EMBEDDING_PROVIDER=dashscope 时需要
DASHSCOPE_API_KEY=
# DashScope 兼容模式 base URL，默认 https://dashscope.aliyuncs.com
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com
# text-embedding-v3 当前锁定 1024 维，与 Prisma schema vector(1024) 和 provider 一致
# 切换维度需同步迁移 schema、provider、chunk-repository 的 vector cast
EMBEDDING_MODEL=text-embedding-v3
# embedding 批处理大小，默认 20
EMBEDDING_BATCH_SIZE=20
# embedding 请求超时（毫秒），默认 30000
EMBEDDING_TIMEOUT_MS=30000

# ---------- LLM / Provider ----------
# 检索/生成 provider 选择：mock（默认）、dashscope（真实 DashScope）、qwen（真实 Qwen-Plus）
# 自动化测试和默认开发环境必须使用 mock，不依赖真实密钥或外网
DASHSCOPE_API_KEY=
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# embedding provider：mock（默认）、dashscope（真实 DashScope text-embedding-v3）
# 与 worker EMBEDDING_PROVIDER 保持配置模型、维度和 base URL 一致
# EMBEDDING_PROVIDER 已在上方 embedding 段定义，此处不重复

# rerank provider：mock（默认）、dashscope（真实 DashScope gte-rerank）
RERANK_PROVIDER=mock
# rerank 请求超时（毫秒），默认 30000
RERANK_TIMEOUT_MS=30000
# rerank 模型，默认 gte-rerank
RERANK_MODEL=gte-rerank

# LLM provider：mock（默认）、qwen（真实 Qwen-Plus）
LLM_PROVIDER=mock
# LLM 模型，默认 qwen-plus
LLM_MODEL=qwen-plus
# LLM 请求超时（毫秒），默认 60000
LLM_TIMEOUT_MS=60000

# 检索低相关拒答阈值，默认 0.2；评测系统建立前不调优
RETRIEVAL_LOW_RELEVANCE_THRESHOLD=0.2

# ---------- Cloudflare R2 ----------
# Change 1 不需要填写；Change 5 需要
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_BUCKET=

# ---------- Langfuse (LLM trace) ----------
# Change 1 不需要填写；Change 10/11 需要
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ---------- Sentry ----------
# Change 1 不需要填写；Change 10/11 需要
SENTRY_DSN=

# ---------- Better Stack ----------
# Change 1 不需要填写；Change 11 需要
BETTERSTACK_HEARTBEAT_URL=

# ---------- Next.js 前端 ----------
# API 服务地址（仅供 next.config.ts 服务端 rewrite 使用，客户端自动走相对路径 /api/*、/auth/*）
API_URL=http://localhost:3001

# ---------- 环境 ----------
NODE_ENV=development