    "/auth/register": {
      "post": {
        "operationId": "AuthController_register",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "注册成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "409": {
            "description": "邮箱已注册"
          },
          "429": {
            "description": "请求过于频繁"
          }
        },
        "summary": "用户注册",
        "tags": [
          "Auth"
        ]
      }
    },
    "/auth/login": {
      "post": {
        "operationId": "AuthController_login",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "登录成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "401": {
            "description": "邮箱或密码错误"
          },
          "429": {
            "description": "请求过于频繁"
          }
        },
        "summary": "用户登录",
        "tags": [
          "Auth"
        ]
      }
    },
    "/auth/refresh": {
      "post": {
        "operationId": "AuthController_refresh",
        "parameters": [],
        "responses": {
          "200": {
            "description": "刷新成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "401": {
            "description": "refresh token 无效或已过期"
          },
          "429": {
            "description": "请求过于频繁"
          }
        },
        "summary": "刷新 access token（需要 refresh cookie）",
        "tags": [
          "Auth"
        ]
      }
    },
    "/auth/logout": {
      "post": {
        "operationId": "AuthController_logout",
        "parameters": [],
        "responses": {
          "200": {
            "description": "已退出"
          }
        },
        "summary": "退出登录（需要 refresh cookie）",
        "tags": [
          "Auth"
        ]
      }
    },
    "/auth/me": {
      "get": {
        "operationId": "AuthController_me",
        "parameters": [],
        "responses": {
          "200": {
            "description": "当前用户信息",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthUserResponse"
                }
              }
            }
          },
          "401": {
            "description": "未认证"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "获取当前用户信息",
        "tags": [
          "Auth"
        ]
      }
    },
    "/kbs": {
      "post": {
        "operationId": "KnowledgeBaseController_create",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateKbDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "KB 创建成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/KbResponse"
                }
              }
            }
          },
          "400": {
            "description": "输入校验失败（含传入 spaceId 被拒绝的场景）"
          },
          "401": {
            "description": "未认证"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "创建个人 KB",
        "tags": [
          "KnowledgeBase"
        ]
      },
      "get": {
        "operationId": "KnowledgeBaseController_list",
        "parameters": [],
        "responses": {
          "200": {
            "description": "个人 KB 列表（按 updatedAt desc, id desc 排序）",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/KbListResponse"
                }
              }
            }
          },
          "401": {
            "description": "未认证"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "列出个人 KB",
        "tags": [
          "KnowledgeBase"
        ]
      }
    },
    "/kbs/{id}": {
      "get": {
        "operationId": "KnowledgeBaseController_detail",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "description": "KB ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "KB 详情",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/KbResponse"
                }
              }
            }
          },
          "401": {
            "description": "未认证"
          },
          "404": {
            "description": "KB 不存在或无权访问"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "获取 KB 详情",
        "tags": [
          "KnowledgeBase"
        ]
      }
    },
    "/uploads/presign": {
      "post": {
        "operationId": "UploadsController_presign",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PresignUploadDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "上传初始化成功，返回直传 URL",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PresignUploadResponse"
                }
              }
            }
          },
          "400": {
            "description": "校验失败"
          },
          "401": {
            "description": "未认证"
          },
          "404": {
            "description": "KB 不存在或无权访问"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Markdown 上传初始化",
        "tags": [
          "Uploads"
        ]
      }
    },
    "/documents": {
      "post": {
        "operationId": "DocumentsController_create",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateDocumentDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Document 创建成功并入队",
