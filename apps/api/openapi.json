          "Documents"
        ]
      }
    },
    "/kbs/{kbId}/documents": {
      "get": {
        "operationId": "DocumentsController_listByKb",
        "parameters": [
          {
            "name": "kbId",
            "required": true,
            "in": "path",
            "description": "KB ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Document 列表",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DocumentListResponse"
                }
              }
            }
          },
          "401": {
            "description": "未认证"
          },
          "404": {
            "description": "KB 不存在或无权访问"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "列出 KB 下 Document",
        "tags": [
          "Documents"
        ]
      }
    },
    "/documents/{id}/chunks": {
      "get": {
        "operationId": "DocumentsController_getChunks",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "description": "Document ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "required": false,
            "in": "query",
            "description": "每页数量，默认 100，最大 500",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "cursor",
            "required": false,
            "in": "query",
            "description": "分页 cursor",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Chunk 列表",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChunkListResponse"
                }
              }
            }
          },
          "401": {
            "description": "未认证"
          },
          "404": {
            "description": "Document 不存在或无权访问"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "查询 Document 的 chunks",
        "tags": [
          "Documents"
        ]
      }
    }
  },
  "info": {
    "title": "DevBrain API",
    "description": "DevBrain 知识库 API",
    "version": "0.1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      },
      "cookie": {
        "type": "apiKey",
        "in": "cookie",
        "name": "devbrain_refresh"
      }
    },
    "schemas": {
      "RegisterDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "description": "用户邮箱",
            "example": "user@example.com"
          },
          "password": {
            "type": "string",
            "description": "密码（8-128 个字符）",
            "example": "SecurePass123!",
            "minLength": 8,
            "maxLength": 128
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "AuthUserResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "用户 ID"
          },
          "email": {
            "type": "string",
            "description": "用户邮箱"
          },
          "status": {
            "type": "string",
            "description": "用户状态"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string",
            "description": "注册时间"
          }
        },
        "required": [
          "id",
          "email",
          "status",
          "createdAt"
        ]
      },
      "AuthResponse": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string",
            "description": "JWT access token"
          },
          "user": {
            "description": "当前用户信息",
            "allOf": [
              {
                "$ref": "#/components/schemas/AuthUserResponse"
              }
            ]
          }
        },
        "required": [
          "accessToken",
          "user"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "description": "用户邮箱",
            "example": "user@example.com"
          },
          "password": {
            "type": "string",
            "description": "密码",
            "example": "SecurePass123!"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "CreateKbDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "KB 名称（1-200 个字符）",
            "example": "我的知识库",
            "minLength": 1,
            "maxLength": 200
          },
          "description": {
            "type": "string",
            "description": "KB 描述（最多 500 个字符）",
            "example": "存放项目文档和笔记",
            "maxLength": 500
          }
        },
        "required": [
          "name"
        ]
      },
      "KbResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "KB ID"
          },
          "name": {
            "type": "string",
            "description": "KB 名称"
          },
          "description": {
            "type": "string",
            "description": "KB 描述"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string",
            "description": "创建时间"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string",
            "description": "更新时间"
          }
        },
        "required": [
          "id",
          "name",
          "createdAt",
          "updatedAt"
        ]
      },
      "KbListResponse": {
        "type": "object",
        "properties": {
          "items": {
            "description": "KB 列表",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/KbResponse"
            }
          }
        },
        "required": [
          "items"
        ]
      },
      "PresignUploadDto": {
        "type": "object",
        "properties": {
          "kbId": {
            "type": "string",
            "description": "目标 KB ID"
          },
          "fileName": {
            "type": "string",
            "description": "文件名"
          },
          "mimeType": {
            "type": "string",
            "description": "MIME 类型"
          },
          "sizeBytes": {
            "type": "number",
            "description": "文件大小（字节）",
            "maximum": 20971520
          }
        },
        "required": [
          "kbId",
          "fileName",
          "mimeType",
          "sizeBytes"
        ]
      },
      "PresignUploadResponse": {
        "type": "object",
        "properties": {
          "uploadUrl": {
            "type": "string",
            "description": "上传 URL"
          },
          "uploadMethod": {
            "type": "string",
            "description": "HTTP 方法"
          },
          "objectKey": {
            "type": "string",
            "description": "对象存储 key"
          },
          "expiresAt": {
            "format": "date-time",
            "type": "string",
            "description": "签名过期时间"
          },
          "uploadToken": {
            "type": "string",
            "description": "创建 Document 所需 token"
          }
        },
        "required": [
          "uploadUrl",
          "uploadMethod",
          "objectKey",
          "expiresAt",
          "uploadToken"
        ]
      },
      "CreateDocumentDto": {
        "type": "object",
        "properties": {
          "kbId": {
            "type": "string",
            "description": "目标 KB ID"
          },
          "objectKey": {
            "type": "string",
            "description": "对象存储 key"
          },
          "uploadToken": {
            "type": "string",
            "description": "上传签名 token"
          },
          "originalName": {
            "type": "string",
            "description": "原始文件名"
          },
          "mimeType": {
            "type": "string",
            "description": "MIME 类型"
          },
          "sizeBytes": {
            "type": "number",
            "description": "文件大小（字节）"
          }
        },
        "required": [
          "kbId",
          "objectKey",
          "uploadToken",
          "originalName"
        ]
      },
      "DocumentResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Document ID"
          },
          "kbId": {
            "type": "string",
            "description": "所属 KB ID"
          },
          "sourceType": {
            "type": "string",
            "description": "来源类型"
          },
          "originalName": {
            "type": "string",
            "description": "原始文件名"
          },
          "status": {
            "type": "string",
            "description": "处理状态"
          },
          "errorCode": {
            "type": "string",
            "description": "错误码",
            "nullable": true
          },
          "errorMessage": {
            "type": "string",
            "description": "错误信息",
            "nullable": true
          },
          "createdAt": {
            "format": "date-time",
            "type": "string",
            "description": "创建时间"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string",
            "description": "更新时间"
          }
        },
        "required": [
          "id",
          "kbId",
          "sourceType",
          "originalName",
          "status",
          "createdAt",
          "updatedAt"
        ]
      },
      "DocumentListResponse": {
        "type": "object",
        "properties": {
          "items": {
            "description": "Document 列表",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DocumentResponse"
            }
          }
        },
        "required": [
          "items"
        ]
      },
      "ChunkResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Chunk ID"
          },
          "documentId": {
            "type": "string",
            "description": "所属 Document ID"
          },
          "kbId": {
            "type": "string",
            "description": "所属 KB ID"
          },
          "sourceType": {
            "type": "string",
            "description": "来源类型"
          },
          "content": {
            "type": "string",
            "description": "文本内容"
          },
          "headingPath": {
            "description": "标题路径",
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "anchor": {
            "type": "string",
            "description": "定位锚点"
          },
          "tokenCount": {
            "type": "number",
            "description": "token 数量"
          },
          "metadata": {
            "type": "object",
            "description": "元数据"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string",
            "description": "创建时间"
          }
        },
        "required": [
          "id",
          "documentId",
          "kbId",
          "sourceType",
          "content",
          "headingPath",
          "anchor",
          "tokenCount",
          "metadata",
          "createdAt"
        ]
      },
      "ChunkListResponse": {
        "type": "object",
        "properties": {
          "items": {
            "description": "Chunk 列表",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ChunkResponse"
            }
          },
          "nextCursor": {
            "type": "string",
            "description": "下一页 cursor",
            "nullable": true
          }
        },
        "required": [
          "items"
        ]
      }
    }
  }
}