{
  "openapi": "3.0.0",
  "paths": {
    "/healthz": {
      "get": {
        "operationId": "HealthController_check",
        "parameters": [],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "tags": [
          "Health"
        ]
      }
    },
    "/readyz": {
      "get": {
        "operationId": "ReadyzController_check",
        "parameters": [],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "tags": [
          "Readyz"
        ]
      }
    },
    "/auth/register": {
      "post": {
        "operationId": "AuthController_register",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "注册成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "409": {
            "description": "邮箱已注册"
          },
          "429": {
            "description": "请求过于频繁"
          }
        },
        "summary": "用户注册",
        "tags": [
          "Auth"
        ]
      }
    },
    "/auth/login": {
      "post": {
        "operationId": "AuthController_login",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "登录成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "401": {
            "description": "邮箱或密码错误"
          },
          "429": {
            "description": "请求过于频繁"
          }
        },
        "summary": "用户登录",
        "tags": [
          "Auth"
        ]
      }
    },
    "/auth/refresh": {
      "post": {
        "operationId": "AuthController_refresh",
        "parameters": [],
        "responses": {
          "200": {
            "description": "刷新成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "401": {
            "description": "refresh token 无效或已过期"
          },
          "429": {
            "description": "请求过于频繁"
          }
        },
        "summary": "刷新 access token（需要 refresh cookie）",
        "tags": [
          "Auth"
        ]
      }
    },
    "/auth/logout": {
      "post": {
        "operationId": "AuthController_logout",
        "parameters": [],
        "responses": {
          "200": {
            "description": "已退出"
          }
        },
        "summary": "退出登录（需要 refresh cookie）",
        "tags": [
          "Auth"
        ]
      }
    },
    "/auth/me": {
      "get": {
        "operationId": "AuthController_me",
        "parameters": [],
        "responses": {
          "200": {
            "description": "当前用户信息",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthUserResponse"
                }
              }
            }
          },
          "401": {
            "description": "未认证"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "获取当前用户信息",
        "tags": [
          "Auth"
        ]
      }
    },
    "/kbs": {
      "post": {
        "operationId": "KnowledgeBaseController_create",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateKbDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "KB 创建成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/KbResponse"
                }
              }
            }
          },
          "400": {
            "description": "输入校验失败（含传入 spaceId 被拒绝的场景）"
          },
          "401": {
            "description": "未认证"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "创建个人 KB",
        "tags": [
          "KnowledgeBase"
        ]
      },
      "get": {
        "operationId": "KnowledgeBaseController_list",
        "parameters": [],
        "responses": {
          "200": {
            "description": "个人 KB 列表（按 updatedAt desc, id desc 排序）",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/KbListResponse"
                }
              }
            }
          },
          "401": {
            "description": "未认证"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "列出个人 KB",
        "tags": [
          "KnowledgeBase"
        ]
      }
    },
    "/kbs/{id}": {
      "get": {
        "operationId": "KnowledgeBaseController_detail",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "description": "KB ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "KB 详情",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/KbResponse"
                }
              }
            }
          },
          "401": {
            "description": "未认证"
          },
          "404": {
            "description": "KB 不存在或无权访问"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "获取 KB 详情",
        "tags": [
          "KnowledgeBase"
        ]
      }
    }
  },
  "info": {
    "title": "DevBrain API",
    "description": "DevBrain 知识库 API",
    "version": "0.1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      },
      "cookie": {
        "type": "apiKey",
        "in": "cookie",
        "name": "devbrain_refresh"
      }
    },
    "schemas": {
      "RegisterDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "description": "用户邮箱",
            "example": "user@example.com"
          },
          "password": {
            "type": "string",
            "description": "密码（8-128 个字符）",
            "example": "SecurePass123!",
            "minLength": 8,
            "maxLength": 128
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "AuthUserResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "用户 ID"
          },
          "email": {
            "type": "string",
            "description": "用户邮箱"
          },
          "status": {
            "type": "string",
            "description": "用户状态"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string",
            "description": "注册时间"
          }
        },
        "required": [
          "id",
          "email",
          "status",
          "createdAt"
        ]
      },
      "AuthResponse": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string",
            "description": "JWT access token"
          },
          "user": {
            "description": "当前用户信息",
            "allOf": [
              {
                "$ref": "#/components/schemas/AuthUserResponse"
              }
            ]
          }
        },
        "required": [
          "accessToken",
          "user"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "description": "用户邮箱",
            "example": "user@example.com"
          },
          "password": {
            "type": "string",
            "description": "密码",
            "example": "SecurePass123!"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "CreateKbDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "KB 名称（1-200 个字符）",
            "example": "我的知识库",
            "minLength": 1,
            "maxLength": 200
          },
          "description": {
            "type": "string",
            "description": "KB 描述（最多 500 个字符）",
            "example": "存放项目文档和笔记",
            "maxLength": 500
          }
        },
        "required": [
          "name"
        ]
      },
      "KbResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "KB ID"
          },
          "name": {
            "type": "string",
            "description": "KB 名称"
          },
          "description": {
            "type": "string",
            "description": "KB 描述"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string",
            "description": "创建时间"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string",
            "description": "更新时间"
          }
        },
        "required": [
          "id",
          "name",
          "createdAt",
          "updatedAt"
        ]
      },
      "KbListResponse": {
        "type": "object",
        "properties": {
          "items": {
            "description": "KB 列表",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/KbResponse"
            }
          }
        },
        "required": [
          "items"
        ]
      }
    }
  }
}