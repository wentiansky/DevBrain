              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DocumentResponse"
                }
              }
            }
          },
          "400": {
            "description": "校验失败"
          },
          "401": {
            "description": "未认证"
          },
          "404": {
            "description": "KB 不存在或无权访问"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "创建 Document",
        "tags": [
          "Documents"
        ]
      }
    },
    "/documents/{id}": {
      "get": {
        "operationId": "DocumentsController_detail",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "description": "Document ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Document 详情",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DocumentResponse"
                }
              }
            }
          },
          "401": {
            "description": "未认证"
          },
          "404": {
            "description": "Document 不存在或无权访问"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "获取 Document 详情",
